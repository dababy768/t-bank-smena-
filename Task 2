import json
import os

FILE_NAME = "library.json"


def load_books():
    if not os.path.exists(FILE_NAME):
        return []
    try:
        with open(FILE_NAME, "r", encoding="utf-8") as f:
            data = json.load(f)
            if isinstance(data, list):
                return data
    except:
        pass
    return []


def save_books(books):
    with open(FILE_NAME, "w", encoding="utf-8") as f:
        json.dump(books, f, ensure_ascii=False, indent=4)


def next_id(books):
    if not books:
        return 1
    return max(book["id"] for book in books) + 1


def input_non_empty(text):
    while True:
        value = input(text).strip()
        if value:
            return value
        print("Поле не должно быть пустым.")


def input_year():
    while True:
        year = input("Введите год издания: ").strip()
        if year.isdigit():
            return int(year)
        print("Год должен быть числом.")


def find_book_by_id(books, book_id):
    for book in books:
        if book["id"] == book_id:
            return book
    return None


def print_book(book):
    fav = "Да" if book["favorite"] else "Нет"
    print(f'ID: {book["id"]}')
    print(f'Название: {book["title"]}')
    print(f'Автор: {book["author"]}')
    print(f'Жанр: {book["genre"]}')
    print(f'Год издания: {book["year"]}')
    print(f'Описание: {book["description"]}')
    print(f'Статус: {book["status"]}')
    print(f'В избранном: {fav}')
    print("-" * 40)


def add_book(books):
    title = input_non_empty("Введите название книги: ")
    author = input_non_empty("Введите автора: ")
    genre = input_non_empty("Введите жанр: ")
    year = input_year()
    description = input("Введите краткое описание: ").strip()
    book = {
        "id": next_id(books),
        "title": title,
        "author": author,
        "genre": genre,
        "year": year,
        "description": description,
        "status": "не прочитана",
        "favorite": False
    }
    books.append(book)
    save_books(books)
    print("Книга успешно добавлена.")


def show_books(books):
    if not books:
        print("Библиотека пуста.")
        return

    result = books[:]

    print("Сортировка:")
    print("1. Без сортировки")
    print("2. По названию")
    print("3. По автору")
    print("4. По году издания")
    sort_choice = input("Выберите вариант: ").strip()

    if sort_choice == "2":
        result.sort(key=lambda x: x["title"].lower())
    elif sort_choice == "3":
        result.sort(key=lambda x: x["author"].lower())
    elif sort_choice == "4":
        result.sort(key=lambda x: x["year"])

    genre_filter = input("Введите жанр для фильтрации или оставьте пустым: ").strip().lower()
    if genre_filter:
        result = [book for book in result if book["genre"].lower() == genre_filter]

    print("Фильтр по статусу:")
    print("1. Все")
    print("2. Прочитанные")
    print("3. Не прочитанные")
    status_choice = input("Выберите вариант: ").strip()

    if status_choice == "2":
        result = [book for book in result if book["status"] == "прочитана"]
    elif status_choice == "3":
        result = [book for book in result if book["status"] == "не прочитана"]

    if not result:
        print("Книги не найдены.")
        return

    for book in result:
        print_book(book)


def add_to_favorites(books):
    try:
        book_id = int(input("Введите ID книги: "))
    except:
        print("Некорректный ID.")
        return

    book = find_book_by_id(books, book_id)
    if not book:
        print("Книга не найдена.")
        return

    book["favorite"] = True
    save_books(books)
    print("Книга добавлена в избранное.")


def remove_from_favorites(books):
    try:
        book_id = int(input("Введите ID книги: "))
    except:
        print("Некорректный ID.")
        return

    book = find_book_by_id(books, book_id)
    if not book:
        print("Книга не найдена.")
        return

    book["favorite"] = False
    save_books(books)
    print("Книга удалена из избранного.")


def change_status(books):
    try:
book_id = int(input("Введите ID книги: "))
    except:
        print("Некорректный ID.")
        return

    book = find_book_by_id(books, book_id)
    if not book:
        print("Книга не найдена.")
        return

    print("1. Прочитана")
    print("2. Не прочитана")
    choice = input("Выберите новый статус: ").strip()

    if choice == "1":
        book["status"] = "прочитана"
    elif choice == "2":
        book["status"] = "не прочитана"
    else:
        print("Некорректный выбор.")
        return

    save_books(books)
    print("Статус книги обновлен.")


def show_favorites(books):
    favorites = [book for book in books if book["favorite"]]
    if not favorites:
        print("Список избранного пуст.")
        return
    for book in favorites:
        print_book(book)


def delete_book(books):
    try:
        book_id = int(input("Введите ID книги для удаления: "))
    except:
        print("Некорректный ID.")
        return

    book = find_book_by_id(books, book_id)
    if not book:
        print("Книга не найдена.")
        return

    books.remove(book)
    save_books(books)
    print("Книга удалена из библиотеки.")


def search_books(books):
    query = input("Введите ключевое слово: ").strip().lower()
    if not query:
        print("Пустой запрос.")
        return

    result = []
    for book in books:
        if (
            query in book["title"].lower()
            or query in book["author"].lower()
            or query in book["description"].lower()
        ):
            result.append(book)

    if not result:
        print("Книги не найдены.")
        return

    for book in result:
        print_book(book)


def recommend_books(books):
    if not books:
        print("Библиотека пуста.")
        return

    scores = {}
    for book in books:
        genre = book["genre"]
        if genre not in scores:
            scores[genre] = 0
        if book["favorite"]:
            scores[genre] += 3
        if book["status"] == "прочитана":
            scores[genre] += 2

    if not scores:
        print("Недостаточно данных для рекомендаций.")
        return

    favorite_genres = sorted(scores.items(), key=lambda x: (-x[1], x[0].lower()))
    best_genres = [genre for genre, _ in favorite_genres[:3]]

    recommendations = [
        book for book in books
        if book["genre"] in best_genres and book["status"] == "не прочитана"
    ]

    if not recommendations:
        print("Подходящих рекомендаций пока нет.")
        return

    print("Рекомендуемые книги:")
    for book in recommendations:
        print_book(book)


def menu():
    books = load_books()

    while True:
        print("\nТ-Библиотека")
        print("1. Добавить книгу")
        print("2. Показать книги")
        print("3. Добавить в избранное")
        print("4. Удалить из избранного")
        print("5. Изменить статус книги")
        print("6. Показать избранные книги")
        print("7. Удалить книгу")
        print("8. Поиск книги")
        print("9. Рекомендованные книги")
        print("0. Выход")

        choice = input("Выберите действие: ").strip()

        if choice == "1":
            add_book(books)
        elif choice == "2":
            show_books(books)
        elif choice == "3":
            add_to_favorites(books)
        elif choice == "4":
            remove_from_favorites(books)
        elif choice == "5":
            change_status(books)
        elif choice == "6":
            show_favorites(books)
        elif choice == "7":
            delete_book(books)
        elif choice == "8":
            search_books(books)
        elif choice == "9":
            recommend_books(books)
        elif choice == "0":
            save_books(books)
            print("Данные сохранены. До свидания.")
            break
        else:
            print("Некорректный выбор.")


menu()
